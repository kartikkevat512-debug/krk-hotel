  </div>

  <div class="card">
    <h3>Cold Drink</h3>
    <p>Chilled soft drinks available.</p>
  </div>

  <div class="card">
    <h3>Snacks</h3>
    <p>Tea-time snacks and light food.</p>
  </div>
</div>

  </section>  <footer>
    <p>📞 WhatsApp: 7354973753</p>
